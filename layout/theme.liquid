<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">

  <head>
    {% comment %} Required by shopify: Must be first line inside head{% endcomment %}
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {{ content_for_header }}
    <title>{{ page.title }}</title>
    {{'vikram-theme.css' | asset_url | stylesheet_tag }}

 </head>

 <body>
  {% section 'header' %}
  <main>
    {{ content_for_layout }}
  </main>
  {% section 'footer' %}
 </body>
</html>

<header class="site-header">
  <div class="page-width header-inner">
    <a href="{{ routes.root_url }}">
      <span>{{ shop.name }}</span>
    </a>

    <nav class="header-nav">
      <ul >
        {% for link in linklists[section.settings.menu].links %}
          <li>
            <a href="{{ link.url }}">{{ link.title }}</a>
          </li>
        {% endfor %}
      </ul>
    </nav>
    {%render 'icon-cart'%}
  </div>
</header>


{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
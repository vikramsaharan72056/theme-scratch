<div class="collection-page">
  <div class="page-width">
    <h1>{{ collection.title }}</h1>
    {% if collection.description != blank %}
      <p>{{ collection.description }}</p>
    {% endif %}

    {% paginate collection.products by section.settings.products_per_page %}
      {% if collection.products_count > 0 %}
        <div class="product-grid">
          {% for product in collection.products %}
            {% render 'product-card', product: product %}
          {% endfor %}
        </div>
      {% else %}
        <p class="collection-empty">No products found in this collection.</p>
      {% endif %}

      {% if paginate.pages > 1 %}
        <nav class="pagination" role="navigation" aria-label="Collection pagination">
          <ul class="pagination-list">
            <li>
              {% if paginate.previous %}
                <a class="pagination-link pagination-prev" href="{{ paginate.previous.url }}">Previous</a>
              {% else %}
                <span class="pagination-link pagination-prev is-disabled" aria-disabled="true">Previous</span>
              {% endif %}
            </li>

            {% for part in paginate.parts %}
              <li>
                {% if part.is_link %}
                  <a class="pagination-link" href="{{ part.url }}" aria-label="Go to page {{ part.title }}">{{ part.title }}</a>
                {% else %}
                  {% if part.title == '&hellip;' %}
                    <span class="pagination-ellipsis">{{ part.title }}</span>
                  {% else %}
                    <span class="pagination-link is-current" aria-current="page">{{ part.title }}</span>
                  {% endif %}
                {% endif %}
              </li>
            {% endfor %}

            <li>
              {% if paginate.next %}
                <a class="pagination-link pagination-next" href="{{ paginate.next.url }}">Next</a>
              {% else %}
                <span class="pagination-link pagination-next is-disabled" aria-disabled="true">Next</span>
              {% endif %}
            </li>
          </ul>
        </nav>
      {% endif %}
    {% endpaginate %}
  </div>
</div>


{% schema %}

{
    "name":"Collection Products",
    "settings": [
      {
        "type": "range",
        "id": "products_per_page",
        "label": "Products per page",
        "min": 4,
        "max": 24,
        "step": 4,
        "default": 8
      }
    ]
}

{% endschema %}
